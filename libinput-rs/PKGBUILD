pkgname=libinput-rs
pkgver=0.1.1
pkgrel=1
pkgdesc="Rust replacement for libinput with a libinput.so.0-compatible ABI"
arch=('x86_64')
url="https://github.com/SisyphusAeolides/libinput-rs"
license=('MIT')
depends=('glibc')
makedepends=('cargo')
provides=('libinput.so=0-64')
conflicts=('libinput')
backup=('etc/libinput-rs/config.json')
_commit=f53e20b7eff85b63f4f8408f94093e47b8a801e6
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/${_commit}.tar.gz")
sha256sums=('9203745ee0ba42b27ab18eb02b7fd48199db0046662139b610e5d062965dbd2e')

prepare() {
  cd "${pkgname}-${_commit}"
  sed -i 's|/usr/sbin/modprobe|/usr/bin/modprobe|g' libinput-elan-reset.service
}

build() {
  cd "${pkgname}-${_commit}"
  cargo build --release --locked
}

package() {
  cd "${pkgname}-${_commit}"

  install -Dm755 target/release/libinput-rs "${pkgdir}/usr/bin/libinput-rs"
  install -Dm755 target/release/libinput.so "${pkgdir}/usr/lib/libinput.so.0"
  ln -s libinput.so.0 "${pkgdir}/usr/lib/libinput.so"
  install -Dm644 src/config.json "${pkgdir}/etc/libinput-rs/config.json"
  install -Dm644 systemd/libinput-rs.service \
    "${pkgdir}/usr/lib/systemd/system/libinput-rs.service"
  install -Dm644 libinput-elan-reset.service \
    "${pkgdir}/usr/lib/systemd/system/libinput-elan-reset.service"
}

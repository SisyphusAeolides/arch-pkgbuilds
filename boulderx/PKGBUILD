pkgname=boulderx
pkgver=0.6.2
pkgrel=3
pkgdesc="GTK4 IRC, Matrix, and Discord bot client"
arch=('x86_64')
url="https://github.com/SisyphusAeolides/boulderX"
license=('GPL-2.0-or-later')
depends=('gtk4' 'libadwaita' 'openssl' 'sqlite')
makedepends=('appstream' 'cargo' 'desktop-file-utils' 'git' 'pkgconf')
options=('!lto')
_commit=5f07470571340b9a817e5f78f6eb919f57affeda
source=("git+${url}.git#commit=${_commit}")
sha256sums=('SKIP')

build() {
  cd "boulderX"
  export RUSTFLAGS="${RUSTFLAGS:+${RUSTFLAGS} }--remap-path-prefix=${srcdir}=/usr/src/debug/${pkgname}"
  cargo build --release --locked --offline
}

check() {
  cd "boulderX"
  desktop-file-validate packaging/io.github.sisyphusaeolides.boulderx.desktop
  appstreamcli validate --no-net packaging/io.github.sisyphusaeolides.boulderx.metainfo.xml
}

package() {
  cd "boulderX"

  install -Dm755 target/release/boulderX "${pkgdir}/usr/bin/boulderX"
  install -Dm644 packaging/io.github.sisyphusaeolides.boulderx.desktop \
    "${pkgdir}/usr/share/applications/io.github.sisyphusaeolides.boulderx.desktop"
  install -Dm644 assets/boulder-relay-128.png \
    "${pkgdir}/usr/share/icons/hicolor/128x128/apps/boulderX.png"
  install -Dm644 assets/boulder-relay-256.png \
    "${pkgdir}/usr/share/icons/hicolor/256x256/apps/boulderX.png"
  install -Dm644 packaging/io.github.sisyphusaeolides.boulderx.metainfo.xml \
    "${pkgdir}/usr/share/metainfo/io.github.sisyphusaeolides.boulderx.metainfo.xml"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}

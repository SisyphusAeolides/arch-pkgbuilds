pkgname=libinput-rs
pkgver=0.1.1
pkgrel=7
pkgdesc="Rust replacement for libinput with libinput.so.10 ABI compatibility"
arch=('x86_64')
url="https://github.com/SisyphusAeolides/libinput-rs"
license=('MIT')
depends=('glibc')
makedepends=('cargo')
provides=('libinput' 'libinput.so=10-64')
conflicts=('libinput')
replaces=('libinput')
backup=('etc/libinput-rs/config.json')

_commit=8788ff208ab301f8c852d77b10d2a805d3fd4b14
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/${_commit}.tar.gz")
sha256sums=('4f660799ed569f401d4d3f8e09588cf27cfe5565bb57e879b3946928720f25f9')

build() {
  cd "${srcdir}/${pkgname}-${_commit}"
  export RUSTFLAGS="${RUSTFLAGS:+${RUSTFLAGS} }--remap-path-prefix=${srcdir}=/usr/src/debug/${pkgname}"
  ./build-shared.sh
  cargo build --bin libinput-rs --release --locked
}

package() {
  cd "${srcdir}/${pkgname}-${_commit}"

  install -Dm755 target/release/libinput-rs "${pkgdir}/usr/bin/libinput-rs"
  install -Dm755 target/release/libinput.so "${pkgdir}/usr/lib/libinput.so.10"
  ln -s libinput.so.10 "${pkgdir}/usr/lib/libinput.so"
  install -Dm644 src/config.json "${pkgdir}/etc/libinput-rs/config.json"
  install -Dm644 systemd/libinput-rs.service \
    "${pkgdir}/usr/lib/systemd/system/libinput-rs.service"
  install -Dm644 libinput-elan-reset.service \
    "${pkgdir}/usr/lib/systemd/system/libinput-elan-reset.service"
}
